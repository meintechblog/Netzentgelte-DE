{
  "name": "netzentgelte-de",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "rm -f tsconfig.tsbuildinfo && next typegen && tsc --noEmit",
    "test:watch": "vitest",
    "automation:backfill-koordinator": "node --import tsx scripts/automation/backfill-koordinator.ts --live",
    "automation:backfill-koordinator:dry-run": "node --import tsx scripts/automation/backfill-koordinator.ts --dry-run",
    "automation:backfill-workset": "node --import tsx scripts/automation/backfill-workset.ts",
    "automation:verified-operator-loop": "node --import tsx scripts/automation/verified-operator-loop.ts --live",
    "automation:verified-operator-loop:dry-run": "node --import tsx scripts/automation/verified-operator-loop.ts --dry-run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/db/migrate.mjs",
    "ingest:run": "node --import tsx scripts/ingest/run-ingest.ts",
    "registry:import": "node --import tsx scripts/registry/import-registry.ts",
    "build:shell-registry": "node --import tsx scripts/registry/build-vnbdigital-shell-registry.ts",
    "shells:import": "node --import tsx scripts/registry/import-shell-registry.ts",
    "sources:refresh": "node --import tsx scripts/sources/refresh-sources.ts",
    "sources:audit": "node --import tsx scripts/sources/refresh-sources.ts --mode audit",
    "export:public": "node --import tsx scripts/public/export-public-snapshot.ts"
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "drizzle-orm": "^0.44.5",
    "germany-administrative-geojson": "^1.1.5",
    "next": "^15.2.0",
    "postgres": "^3.4.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/d3-geo": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.34.0",
    "eslint-config-next": "^15.5.12",
    "jsdom": "^26.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.30.3"
}
